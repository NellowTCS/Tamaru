{
  "name": "tamaru",
  "version": "0.1.1",
  "description": "Sairin, the modern, powerful, and compact reactive engine.",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "make-pretty": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,scss,md,html,cjs}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NellowTCS/Tamaru.git"
  },
  "author": "NellowTCS",
  "bugs": {
    "url": "https://github.com/NellowTCS/Tamaru/issues"
  },
  "homepage": "https://github.com/NellowTCS/Tamaru#readme",
  "devDependencies": {
    "@types/node": "^25.2.3",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@nisoku/satori": "^0.1.3"
  }
}
