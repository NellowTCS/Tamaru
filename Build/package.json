{
  "name": "tamaru",
  "version": "0.1.1",
  "type": "module",
  "description": "Skeuomorphic, momentum-based virtual trackball widget for the web.",
  "license": "Apache-2.0",
  "main": "dist/main.cjs",
  "module": "dist/main.mjs",
  "types": "dist/main.d.mts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/main.d.mts",
        "default": "./dist/main.mjs"
      },
      "require": {
        "types": "./dist/main.d.cts",
        "default": "./dist/main.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "make-pretty": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,scss,md,html,cjs}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NellowTCS/Tamaru.git"
  },
  "author": "NellowTCS",
  "bugs": {
    "url": "https://github.com/NellowTCS/Tamaru/issues"
  },
  "homepage": "https://github.com/NellowTCS/Tamaru#readme",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "prettier": "^3.9.0",
    "@tsdown/css": "^0.22.3",
    "tsdown": "^0.22.3",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@nisoku/satori": "^0.1.3",
    "tactus": "^0.0.3"
  }
}
